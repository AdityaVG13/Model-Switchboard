#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/controller-endpoint-defaults.sh" ]; then
  # shellcheck source=controller-endpoint-defaults.sh
  source "$SCRIPT_DIR/controller-endpoint-defaults.sh"
else
  # Installed ctl may live alone in PATH; keep in sync with controller-endpoint-defaults.sh.
  CONTROLLER_ENDPOINT_HOST="${CONTROLLER_ENDPOINT_HOST:-127.0.0.1}"
  CONTROLLER_ENDPOINT_PORT="${CONTROLLER_ENDPOINT_PORT:-8877}"
  CONTROLLER_ENDPOINT_BASE_URL="${CONTROLLER_ENDPOINT_BASE_URL:-http://${CONTROLLER_ENDPOINT_HOST}:${CONTROLLER_ENDPOINT_PORT}}"
fi
CONTROLLER_URL="${MODEL_SWITCHBOARD_URL:-$CONTROLLER_ENDPOINT_BASE_URL}"
CONTROLLER_ROOT="${MODEL_SWITCHBOARD_CONTROLLER_ROOT:-$HOME/Library/Application Support/ModelSwitchboard/Controller}"
CONTROLLER_BIN="${MODEL_SWITCHBOARD_CONTROLLER_BIN:-}"

if [ -z "$CONTROLLER_BIN" ]; then
  for candidate in \
    "$SCRIPT_DIR/../Controller/bin/ModelSwitchboardController" \
    "$HOME/Applications/Model Switchboard.app/Contents/Resources/ModelSwitchboardController" \
    "$HOME/Applications/Model Switchboard Plus.app/Contents/Resources/ModelSwitchboardController"
  do
    if [ -x "$candidate" ]; then CONTROLLER_BIN="$candidate"; break; fi
  done
fi
if [ -z "$CONTROLLER_BIN" ] && command -v ModelSwitchboardController >/dev/null 2>&1; then
  CONTROLLER_BIN="$(command -v ModelSwitchboardController)"
fi

usage() {
  cat <<'USAGE'
Usage: model-switchboardctl <command> [args]

Commands:
  status | summary      Print controller status JSON
  profiles-dir         Print the active profiles directory
  controller-root      Print the active controller root
  capabilities         Print the native CLI contract
  robot-docs [guide]   Print agent-oriented usage guidance
  triage                Print native health and recommendations
  doctor [args]         Run native controller diagnostics
  start <profile>       Start a profile
  stop <profile>        Stop a profile
  restart <profile>     Restart a profile
  switch <profile>      Activate a profile exclusively
  bench <profile>       Start the quick benchmark suite
  bench-all             Benchmark every profile
  stop-all              Stop all managed profiles
  open-app              Launch Model Switchboard
  open-profiles         Open the profiles directory
  completions <shell>   Print shell completions
USAGE
}

api() { curl -fsS "$@"; }

native() {
  if [ -z "$CONTROLLER_BIN" ]; then
    printf 'error: native ModelSwitchboardController executable not found\n' >&2
    exit 3
  fi
  "$CONTROLLER_BIN" "$@" --root "$CONTROLLER_ROOT"
}

json_action() {
  local endpoint="$1" payload="$2"
  api -X POST -H 'Content-Type: application/json' --data-binary "$payload" "$CONTROLLER_URL$endpoint"
  printf '\n'
}

json_string() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "$value"
}

extract_path() {
  local key="$1"
  api "$CONTROLLER_URL/api/status" | plutil -extract "$key" raw -o - -- -
}

completions() {
  local commands='status summary profiles-dir controller-root capabilities triage doctor start stop restart switch bench bench-all stop-all open-app open-profiles'
  case "${1:-}" in
    bash)
      cat <<EOF
_model_switchboardctl_completion() {
  COMPREPLY=( \$(compgen -W "$commands" -- "\${COMP_WORDS[COMP_CWORD]}") )
}
complete -F _model_switchboardctl_completion model-switchboardctl
EOF
      ;;
    zsh) printf '#compdef model-switchboardctl\n_arguments "1:command:(%s)"\n' "$commands" ;;
    fish) for command in $commands; do printf 'complete -c model-switchboardctl -f -a %s\n' "$command"; done ;;
    *) printf 'error: completions requires bash, zsh, or fish\n' >&2; exit 1 ;;
  esac
}

print_capabilities() {
  cat <<'JSON'
{
  "schema_version": "1",
  "tool": "model-switchboardctl",
  "contract_version": "1.0",
  "default_probe": "model-switchboardctl triage",
  "native_controller": true,
  "commands": ["status", "summary", "profiles-dir", "controller-root", "capabilities", "triage", "doctor", "start", "stop", "restart", "switch", "bench", "bench-all", "stop-all"]
}
JSON
}

print_robot_docs() {
  if [ "${1:-guide}" != "guide" ]; then
    printf 'error: unknown robot-docs topic: %s\n' "$1" >&2
    printf 'did you mean: model-switchboardctl robot-docs guide\n' >&2
    exit 64
  fi
  cat <<'DOCS'
Model Switchboard native controller

- `model-switchboardctl status` is the default read-only probe.
- `model-switchboardctl capabilities` describes available commands.
- Lifecycle commands support `--dry-run` or `--plan` before mutation.
DOCS
}

print_dry_run() {
  local action="$1" endpoint="$2" payload="$3"
  printf '{\n  "schema_version": "1",\n  "tool": "model-switchboardctl",\n  "command": "%s",\n  "dry_run": true,\n  "status": "planned",\n  "ok": true,\n  "plan": [{"endpoint": "%s", "payload": %s}],\n  "results": []\n}\n' "$action" "$endpoint" "$payload"
}

is_dry_run() {
  local argument
  for argument in "$@"; do
    [ "$argument" = "--dry-run" ] || [ "$argument" = "--plan" ] || continue
    return 0
  done
  return 1
}

command="${1:-help}"
shift || true
case "$command" in
  help|-h|--help) usage ;;
  status|summary) api "$CONTROLLER_URL/api/status"; printf '\n' ;;
  profiles-dir) extract_path profiles_dir ;;
  controller-root) extract_path controller_root ;;
  capabilities) print_capabilities ;;
  robot-docs) print_robot_docs "${1:-guide}" ;;
  triage|doctor|diagnose|health) native "$command" "$@" ;;
  start|stop|restart)
    [ "$#" -ge 1 ] || { printf 'error: %s requires a profile\n' "$command" >&2; exit 64; }
    profile="$(json_string "$1")"
    payload="{\"profile\":\"$profile\"}"
    if is_dry_run "$@"; then print_dry_run "$command" "/api/$command" "$payload"; else json_action "/api/$command" "$payload"; fi
    ;;
  switch|activate)
    [ "$#" -ge 1 ] || { printf 'error: %s requires a profile\n' "$command" >&2; exit 64; }
    profile="$(json_string "$1")"
    payload="{\"profile\":\"$profile\"}"
    if is_dry_run "$@"; then print_dry_run "$command" '/api/switch' "$payload"; else json_action '/api/switch' "$payload"; fi
    ;;
  stop-all)
    if is_dry_run "$@"; then print_dry_run 'stop-all' '/api/stop-all' '{}'; else json_action '/api/stop-all' '{}'; fi
    ;;
  bench)
    [ "$#" -ge 1 ] || { printf 'error: bench requires a profile\n' >&2; exit 64; }
    profile="$(json_string "$1")"
    json_action '/api/benchmark/start' "{\"profiles\":[\"$profile\"],\"suite\":\"quick\"}"
    ;;
  bench-all) json_action '/api/benchmark/start' '{"suite":"quick"}' ;;
  open-app) open -a 'Model Switchboard' ;;
  open-profiles) open "$(extract_path profiles_dir)" ;;
  completions) completions "${1:-}" ;;
  *)
    printf 'error: unknown command: %s\n' "$command" >&2
    if [ "$command" = "stats" ]; then printf 'did you mean: model-switchboardctl status\n' >&2; fi
    printf 'inspect available commands with: model-switchboardctl capabilities\n' >&2
    exit 64
    ;;
esac
