# Copy this file, rename it, and replace every placeholder value.

DISPLAY_NAME=Example rvllm-mlx Model
RUNTIME=rvllm-mlx

SERVER_BIN=/absolute/path/to/rvllm-mlx-server
MODEL_DIR=/absolute/path/to/rvllm-mlx-model-directory

HOST=127.0.0.1
PORT=8082
BASE_URL=http://127.0.0.1:8082/v1
REQUEST_MODEL=example-rvllm-mlx-model
SERVER_MODEL_ID=example-rvllm-mlx-model
