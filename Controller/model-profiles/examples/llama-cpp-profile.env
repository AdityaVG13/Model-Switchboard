# Copy this file, rename it, and replace every placeholder value.

DISPLAY_NAME=Example GGUF Model
RUNTIME=llama.cpp

# Use MODEL_PATH directly, or pair MODEL_FILE with MODEL_ROOT.
MODEL_PATH=/absolute/path/to/model.gguf
# MODEL_FILE=example-model.gguf
# MODEL_ROOT=/absolute/path/to/model-directory

# Optional if llama-server is already on PATH.
SERVER_BIN=/absolute/path/to/llama-server

HOST=127.0.0.1
PORT=8080
BASE_URL=http://127.0.0.1:8080/v1
REQUEST_MODEL=example-gguf-model
SERVER_MODEL_ID=example-gguf-model

# Typical llama.cpp tuning values. Adjust for your hardware and model.
CONTEXT_SIZE=8192
N_PARALLEL=1
GPU_LAYERS=999
BATCH_SIZE=512
UBATCH_SIZE=512
FLASH_ATTN=1
REASONING=none
