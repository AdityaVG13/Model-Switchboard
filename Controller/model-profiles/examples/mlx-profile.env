# Copy this file, rename it, and replace every placeholder value.

DISPLAY_NAME=Example MLX Model
RUNTIME=mlx

# Use a local converted model directory, or a MODEL_REPO if your MLX server supports pulling it.
MODEL_DIR=/absolute/path/to/mlx-model-directory
# MODEL_REPO=mlx-community/example-model

# Optional if mlx_lm.server is already on PATH.
SERVER_BIN=/absolute/path/to/mlx_lm.server

HOST=127.0.0.1
PORT=8081
BASE_URL=http://127.0.0.1:8081/v1
REQUEST_MODEL=example-mlx-model
SERVER_MODEL_ID=example-mlx-model

TEMP=0.7
TOP_P=0.95
MAX_TOKENS=1024
PROMPT_CACHE_SIZE=64
PROMPT_CACHE_BYTES=0
PROMPT_CONCURRENCY=1
DECODE_CONCURRENCY=1
PREFILL_STEP_SIZE=512
CHAT_TEMPLATE_ARGS={}
